# Multi-tenant Salon Randevu Sistemi - Ortam Değişkenleri

# API Base URL - Backend'iniz buraya işaret etmeli
# Development: http://localhost:3000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# Salon ID - İçinde bulunulan salon (production'da URL parameter'dan alınacak)
NEXT_PUBLIC_SALON_ID=salon-001

# Müşteri ID - Giriş yapan müşteri (auth system'den gelecek)
NEXT_PUBLIC_CUSTOMER_ID=customer-001

# NOTE:
# Do not set NODE_ENV here for production builds.
# Next.js build should run with NODE_ENV=production.
